# spotflowd configuration file
# Default location: /etc/spotflow/spotflowd.toml
#
# Only [device] is required — all other sections have sensible defaults.
# Uncomment and modify individual settings as needed.

# ---------------------------------------------------------------------------
# Device identity (REQUIRED)
# ---------------------------------------------------------------------------

[device]
id = "my-device-001"
ingest_key = "sk_..."

# ---------------------------------------------------------------------------
# MQTT connection
# ---------------------------------------------------------------------------
# Normally you do not need to change these.

# [mqtt]
# broker = "mqtt.spotflow.io"
# port = 8883
# keepalive_secs = 60

# ---------------------------------------------------------------------------
# Log collection
# ---------------------------------------------------------------------------
# spotflowd can collect logs from two sources: systemd journal and syslog.
#
# On systemd builds (default), journald is enabled and syslog is disabled
# to avoid duplicate entries. On non-systemd builds (Yocto), the opposite
# applies automatically — no config change needed.

# [logs]
# journald = true
# syslog = false
# syslog_path = "/var/log/syslog"

# ---------------------------------------------------------------------------
# Log buffer
# ---------------------------------------------------------------------------
# Logs are held in memory first, then flushed to disk chunks on overflow.
# When the disk spool is full, the oldest chunks are dropped.

# [logs.buffer]
# memory_max_entries = 1000
# disk_path = "/var/lib/spotflow/spool"
# disk_max_size_mb = 64
# disk_chunk_max_entries = 200

# ---------------------------------------------------------------------------
# OS metrics
# ---------------------------------------------------------------------------
# Collects CPU, memory, disk, and network metrics from /proc and /sys.
# Disabled by default — set enabled = true to turn on.

# [metrics]
# enabled = false
# collection_interval_secs = 10
# aggregation_interval = "1m"       # none | 1m | 1h | 1d

# Enable or disable individual metric groups.
# All groups are enabled by default when [metrics] enabled = true.

# [metrics.groups]
# cpu     = true    # cpu_utilization_percent, load averages, temperature
# memory  = true    # mem_used_percent, mem_available_bytes, swap_used_percent
# disk    = true    # disk_free_bytes, disk_used_percent, disk_read/write_bytes
# network = true    # network_rx/tx_bytes, net_rx/tx_errors, net_rx/tx_drops
# system  = true    # uptime_ms, process_count, fd_used, fd_max

# [metrics.disk]
# mount_points = ["/"]

# [metrics.network]
# interfaces = []                   # empty = auto-detect all non-loopback

# ---------------------------------------------------------------------------
# Custom application metrics
# ---------------------------------------------------------------------------
# Any local process can publish metrics via a Unix socket using
# newline-delimited JSON. Independent of OS metrics — works on its own.
#
# Example:  echo '{"name":"queue_depth","value":42}' | nc -UN /run/spotflow/metrics.sock

# [metrics.custom]
# enabled = false
# socket_path = "/run/spotflow/metrics.sock"
