# spotflowd configuration file
# Default location: /etc/spotflow/spotflowd.toml

[device]
# Unique identifier for this device on the Spotflow platform.
id = "my-device-001"
# Ingest key obtained from the Spotflow dashboard.
ingest_key = "sk_..."

[mqtt]
# Spotflow MQTT broker (default: mqtt.spotflow.io).
broker = "mqtt.spotflow.io"
# TLS port (default: 8883).
port = 8883
# MQTT keep-alive interval in seconds (default: 60).
keepalive_secs = 60

[logs]
# Collect logs from systemd journal (requires journald feature, default: true).
journald = true
# Collect logs by tailing a syslog file.
# Default: false on systemd builds (journald already captures everything rsyslog
# writes — enabling both causes duplicate entries). Default: true on Yocto/non-systemd.
syslog = false
# Path to the syslog file. Defaults to /var/log/syslog on Debian/Ubuntu
# or /var/log/messages on RHEL/Yocto systems.
syslog_path = "/var/log/syslog"

[logs.buffer]
# Maximum number of log entries held in memory.
# When this limit is reached, entries are flushed to a disk chunk.
memory_max_entries = 1000

# Directory for on-disk spool chunk files.
disk_path = "/var/lib/spotflow/spool"

# Maximum total size of the disk spool in megabytes.
# When reached, the oldest chunk files are dropped to make room.
disk_max_size_mb = 64

# Number of log entries per disk chunk file.
disk_chunk_max_entries = 200

[metrics]
# Set to true to enable OS metrics collection and upload.
enabled = false

# How often to sample /proc and /sys (seconds). Zephyr SDK default: 10.
collection_interval_secs = 10

# Aggregation window before uploading.
# "none"  → publish each raw sample immediately (highest resolution, most traffic)
# "1m"    → accumulate samples for 1 minute, then upload sum/count/min/max
# "1h"    → accumulate for 1 hour
# "1d"    → accumulate for 1 day
aggregation_interval = "1m"

[metrics.groups]
# Individual metric groups can be disabled to reduce traffic on constrained devices.
cpu     = true   # cpu_usage_percent, load averages, temperature
memory  = true   # mem_used_percent, mem_available_bytes, swap_used_percent
disk    = true   # disk_free_bytes, disk_used_percent, disk_read_bytes, disk_write_bytes
network = true   # net_rx_bytes, net_tx_bytes, net_rx_errors, net_tx_errors
system  = true   # uptime_seconds, process_count

[metrics.disk]
# Mount points to report disk space for.
mount_points = ["/"]

[metrics.network]
# Interfaces to report. Empty = auto-detect all non-loopback interfaces.
interfaces = []

[metrics.custom]
# Accept custom metrics from local applications via a Unix domain socket.
# Independent of [metrics] enabled — works without OS metrics.
enabled = false
# Path to the Unix socket. Any local process can connect and send metrics.
socket_path = "/run/spotflow/metrics.sock"
